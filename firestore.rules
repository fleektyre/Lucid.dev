rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Auth validation helper
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId &&
                    (!incoming().keys().hasAny(['email', 'fullName']) || incoming().email is string);
      allow delete: if false;
    }
    
    match /credit_transactions/{txId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow write: if false; // Server-only
    }
    
    match /ai_usage_logs/{logId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow write: if false; // Server-only
    }
    
    match /projects/{projectId} {
      allow read, write: if isSignedIn();
      
      match /collaborators/{collaboratorId} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /project_versions/{versionId} {
      allow read, write: if isSignedIn();
    }
    
    match /screenshots/{screenshotId} {
      allow read, write: if isSignedIn() && (resource == null || existing().userId == request.auth.uid);
    }
    
    match /test/{docId} {
      allow read: if true;
    }
  }
}
